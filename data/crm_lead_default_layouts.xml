    <!-- LIST -->
    <record id="layout_crm_lead_list" model="mobile.ui.layout">
        <field name="name">CRM Lead - List (Mobile)</field>
        <field name="model_name">crm.lead</field>
        <field name="screen">list</field>
        <field name="active" eval="True"/>
        <field name="include_custom_fields" eval="False"/>
    </record>
    <record id="section_lead_list_card" model="mobile.ui.section">
        <field name="layout_id" ref="layout_crm_lead_list"/>
        <field name="name">Card</field>
        <field name="sequence">10</field>
    </record>
    <record id="field_list_name" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">name</field>
        <field name="sequence">10</field>
        <field name="widget">text</field>
        <field name="list_primary" eval="True"/>
    </record>
    <record id="field_list_partner" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">partner_name</field>
        <field name="sequence">20</field>
        <field name="widget">text</field>
        <field name="list_subtitle" eval="True"/>
    </record>
    <record id="field_list_phone" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">phone</field>
        <field name="sequence">30</field>
        <field name="widget">phone</field>
    </record>
    <record id="field_list_stage" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">stage_id</field>
        <field name="sequence">40</field>
        <field name="widget">stage</field>
    </record>
    <record id="field_list_user" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">user_id</field>
        <field name="sequence">50</field>
        <field name="widget">many2one</field>
    </record>
    <record id="field_list_create_date" model="mobile.ui.field">
        <field name="section_id" ref="section_lead_list_card"/>
        <field name="field_name">create_date</field>
        <field name="sequence">60</field>
        <field name="widget">datetime</field>
    </record>

